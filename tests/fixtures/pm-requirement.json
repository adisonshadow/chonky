{
  "version": "1.0",
  "projectId": "test-project",
  "rules": [
    {
      "id": "RULE-NO-LEGACY",
      "description": "Do not use legacy module APIs",
      "excluded": [
        {
          "type": "import",
          "target": "legacy-module",
          "reason": "Legacy module is deprecated"
        },
        {
          "type": "api",
          "target": "alert",
          "reason": "Use notification service instead"
        }
      ],
      "severity": "warning"
    }
  ]
}
