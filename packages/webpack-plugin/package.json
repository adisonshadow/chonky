{
  "name": "@chonky/webpack-plugin",
  "version": "0.1.1",
  "description": "Chonky Webpack plugin — build integration for Webpack projects",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --external ./loader && tsup src/loader.ts --format cjs --no-dts --no-clean --external ./index",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "prepublishOnly": "yarn run build"
  },
  "peerDependencies": {
    "webpack": "^5.0.0"
  },
  "dependencies": {
    "@chonky/transpiler": "workspace:*"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adisonshadow/chonky.git",
    "directory": "packages/webpack-plugin"
  },
  "bugs": {
    "url": "https://github.com/adisonshadow/chonky/issues"
  },
  "homepage": "https://github.com/adisonshadow/chonky/tree/main/packages/webpack-plugin#readme",
  "keywords": [
    "chonky",
    "webpack",
    "plugin",
    "machine-first"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
