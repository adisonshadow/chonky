{
  "name": "@chonky/runtime",
  "version": "0.1.0",
  "description": "Chonky browser runtime — metadata collection, verify, wrapper component",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./test": {
      "types": "./dist/test.d.ts",
      "import": "./dist/test.mjs",
      "require": "./dist/test.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/test.ts --format cjs,esm --dts",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.5",
    "tsup": "^8.5.1"
  }
}
