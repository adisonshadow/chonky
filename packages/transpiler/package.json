{
  "name": "@chonkylang/transpiler",
  "version": "0.1.1",
  "description": "Chonky Babel/SWC transpiler plugin — preprocessor + AST transforms",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "prepublishOnly": "yarn run build"
  },
  "peerDependencies": {
    "@babel/core": "^7.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adisonshadow/chonky.git",
    "directory": "packages/transpiler"
  },
  "bugs": {
    "url": "https://github.com/adisonshadow/chonky/issues"
  },
  "homepage": "https://github.com/adisonshadow/chonky/tree/main/packages/transpiler#readme",
  "keywords": [
    "chonky",
    "babel",
    "transpiler",
    "typescript",
    "machine-first"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.2",
    "@babel/template": "^7.28.6",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@types/babel__core": "^7",
    "@types/babel__generator": "^7",
    "@types/babel__template": "^7",
    "@types/babel__traverse": "^7.28.0",
    "tsup": "^8.5.1"
  }
}
