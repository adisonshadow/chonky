{
  "name": "@chonky/transpiler",
  "version": "0.1.0",
  "description": "Chonky Babel/SWC transpiler plugin — preprocessor + AST transforms",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@babel/core": "^7.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.2",
    "@babel/template": "^7.28.6",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@types/babel__core": "^7",
    "@types/babel__generator": "^7",
    "@types/babel__template": "^7",
    "@types/babel__traverse": "^7.28.0",
    "tsup": "^8.5.1"
  }
}
