{
  "name": "@chonky/core",
  "version": "0.1.0",
  "description": "Chonky core — unified entry, re-exports from transpiler and runtime",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@chonky/runtime": "workspace:*",
    "@chonky/transpiler": "workspace:*"
  },
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
