{
  "name": "@chonky/ui",
  "version": "0.1.0",
  "description": "Chonky UI — optimized components (Image, etc.)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@chonky/runtime": "workspace:*"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.5",
    "tsup": "^8.5.1"
  }
}
