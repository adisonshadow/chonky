{
  "name": "@chonkylang/devtools",
  "version": "0.1.1",
  "description": "Chonky DevTools — browser extension panel for render metadata visualization",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "clean": "rm -rf dist",
