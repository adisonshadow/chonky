    "prepublishOnly": "yarn run build"
  },
  "dependencies": {
    "@chonkylang/runtime": "workspace:*"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adisonshadow/chonky.git",
    "directory": "packages/devtools"
  },
  "bugs": {
    "url": "https://github.com/adisonshadow/chonky/issues"
  },
  "homepage": "https://github.com/adisonshadow/chonky/tree/main/packages/devtools#readme",
  "keywords": [
    "chonky",
    "devtools",
    "browser",
    "machine-first"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
